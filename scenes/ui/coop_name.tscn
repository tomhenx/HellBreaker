[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/ui/coop_name.gd" id="1"]
[ext_resource type="AudioStreamWAV" path="res://assets/audio/sfx/btn_hover.wav" id="2"]
[ext_resource type="AudioStreamMP3" path="res://assets/audio/sfx/btn_click.mp3" id="3"]

[node name="CoopName" type="Control"]
script = ExtResource("1")

[node name="BG" type="ColorRect" parent="."]

[node name="Panel" type="PanelContainer" parent="."]

[node name="VBox" type="VBoxContainer" parent="Panel"]

[node name="TitleLabel" type="Label" parent="Panel/VBox"]
text = "CO-OP"

[node name="NameLabel" type="Label" parent="Panel/VBox"]
text = "Your name:"

[node name="NameInput" type="LineEdit" parent="Panel/VBox"]
placeholder_text = "Enter name..."
max_length = 20

[node name="HBox" type="HBoxContainer" parent="Panel/VBox"]
alignment = 1

[node name="HostBtn" type="Button" parent="Panel/VBox/HBox"]
text = "HOST"

[node name="JoinBtn" type="Button" parent="Panel/VBox/HBox"]
text = "JOIN"

[node name="PublicCheck" type="CheckBox" parent="Panel/VBox"]
button_pressed = true
text = "Public room (visible in browser)"

[node name="FriendlyFireCheck" type="CheckBox" parent="Panel/VBox"]
text = "Friendly fire"

[node name="BackBtn" type="Button" parent="Panel/VBox"]
size_flags_horizontal = 3
text = "BACK"

[node name="StatusLabel" type="Label" parent="Panel/VBox"]
text = ""

[node name="AudioHover" type="AudioStreamPlayer" parent="."]
stream    = ExtResource("2")
volume_db = -8.0

[node name="AudioClick" type="AudioStreamPlayer" parent="."]
stream    = ExtResource("3")
volume_db = -5.0
